{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "eslint.config.mjs",
    "prettier.config.mjs",
    "vitest.config.ts",
    "playwright.config.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "apps/**/*.js",
    "apps/**/*.mjs",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.js",
    "packages/**/*.mjs",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tools/**/*.js",
    "tools/**/*.mjs",
    "tools/**/*.ts"
  ],
  "exclude": ["node_modules", "tools/architecture/fixtures"]
}
