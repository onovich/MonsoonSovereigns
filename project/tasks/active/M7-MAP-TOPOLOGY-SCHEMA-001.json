  "acceptance_criteria": [
    "Define serializable static topology definitions for District polygon anchors/metadata, route endpoints, explicit route edges, route modes, capacity, seasonality, terrain/risk classes, and stable topology/content hash boundaries.",
    "No row/column/grid/hex axial/cube/regular-lattice-derived adjacency or authority distance remains in the new topology path; old fixture helpers may remain only as legacy tests or explicit debug inputs.",
    "Path previews are derived only from explicit topology route edges: visually adjacent polygons without a route remain unreachable, and perturbing polygon coordinates does not change selected route ids unless route-edge data changes.",
    "Expose read/query surfaces that let UI and AI inspect districts, route edges, path preview reason codes, capacity, seasonal cost, blocked/no-known-route states, and deterministic tie-break evidence without mutating WorldState.",
    "Preserve sim-core isolation from React, Pixi, DOM, Electron, Node file IO, Math.random, Date.now, and render-frame timing.",
    "Specify save/load handling for topology hash and old saves: migrate if safe or return structured rejection without corrupting existing saves."
  ],
  "required_tests": [
    "git status --short",
    "node .agents/skills/monsoon-studio-orchestrator/scripts/taskctl.mjs validate M7-MAP-TOPOLOGY-SCHEMA-001",
    "git diff --check",
    "pnpm --filter @monsoon/sim-core test",
    "pnpm --filter @monsoon/protocol test",
    "pnpm --filter @monsoon/content-runtime test",
    "pnpm --filter @monsoon/save-format test",
    "pnpm check",
    "focused deterministic path/tie-break/topology-hash tests",
    "focused anti-grid tests for visual-adjacency-without-route and geometry-perturbation-without-path-change"
  ],
  "route_to": "systems_architect",
