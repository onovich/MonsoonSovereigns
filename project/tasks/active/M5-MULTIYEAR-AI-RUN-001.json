  "acceptance_criteria": [
    "A headless Node runner executes the accepted M5 slice world for multiple in-game years with AI actors using the same GameCommand paths as the player and without manual rescue commands.",
    "The run records deterministic summary evidence for no deadlock, no invariant failure, bounded AI trace size, bounded error/rejection rates, and explainable no-action/wait/withdraw/target-change reasons.",
    "Repeated runs with the same seed and command schedule produce identical hashes; different seeds remain bounded and do not rely on Math.random, Date.now, or unspecified ordering.",
    "The task does not create telemetry, analytics pipelines, server infrastructure, multiplayer behavior, arbitrary-code AI scripting, personality simulation, or full diplomacy AI."
  ],
  "required_tests": [
    "git status --short",
    "pnpm --filter @monsoon/sim-core test",
    "pnpm --filter @monsoon/sim-ai test",
    "pnpm sim:determinism",
    "pnpm test",
    "Headless M5 multi-year AI run command with fixed seed, fixed duration, no rescue commands, final hash, and AI trace summary.",
    "node .agents/skills/monsoon-studio-orchestrator/scripts/taskctl.mjs validate M5-MULTIYEAR-AI-RUN-001",
    "git diff --check"
  ],
