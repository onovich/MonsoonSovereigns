{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monsoon-sovereigns.local/schemas/task.schema.json",
  "title": "Project Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "summary",
    "milestone",
    "status",
    "owner_role",
    "reviewer_role",
    "risk_level",
    "dependencies",
    "scope",
    "acceptance_criteria",
    "required_tests",
    "branch_or_worktree",
    "threads",
    "route_to",
    "notes",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "milestone": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "DRAFT",
        "READY",
        "IN_PROGRESS",
        "REVIEW",
        "ACCEPTED",
        "CLOSED",
        "BLOCKED",
        "PARTIAL"
      ]
    },
    "owner_role": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_role": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_paths",
        "forbidden_paths"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_tests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "branch_or_worktree": {
      "type": [
        "string",
        "null"
      ]
    },
    "threads": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "route_to": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
