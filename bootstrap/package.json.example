{
  "name": "monsoon-sovereigns",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format:check": "prettier . --check",
    "test": "pnpm -r test"
  }
}
